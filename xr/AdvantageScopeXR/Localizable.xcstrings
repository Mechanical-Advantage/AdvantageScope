    "Scan QR code displayed in AdvantageScope." : {
      "comment" : "Banner text telling the user to scan a QR code displayed in the desktop version of AdvantageScope.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "امسح رمز الاستجابة السريعة (QR) المعروض في AdvantageScope."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escanear el código QR mostrado en AdvantageScope."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scannez le code QR affiché dans AdvantageScope."
          }
