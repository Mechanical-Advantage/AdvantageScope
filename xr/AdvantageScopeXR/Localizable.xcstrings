    "Move %@ to detect environment." : {
      "comment" : "Banner text telling the user to move their device to detect the environment before starting augmented reality. The placeholder is the name of their device (e.g. “iPhone”, “iPad”).",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتحريك %@ لاكتشاف البيئة."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mover %@ para detectar el entorno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déplacez %@ pour détecter l'environnement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "יש להזיז את %@ כדי לזהות את הסביבה."
