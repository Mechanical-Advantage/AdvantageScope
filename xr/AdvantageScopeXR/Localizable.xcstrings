            "state" : "translated",
            "value" : "Ортаны анықтау үшін %@ құрылғысын жылжытыңыз."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mova o %@ para detectar o ambiente."
          }
        },
        "ro" : {
