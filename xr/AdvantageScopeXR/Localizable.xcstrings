    "Update AdvantageScope to the latest version, then try again." : {
      "comment" : "Banner text that appears when communication fails because AdvantageScope (the desktop app) is older than AdvantageScope XR (the iOS app).",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتحديث AdvantageScope إلى أحدث إصدار، ثم حاول مرة أخرى."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actualizar AdvantageScope a la última versión, luego intentar de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mettez à jour AdvantageScope vers la dernière version, puis réessayez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "יש לעדכן את AdvantageScope לגרסה העדכנית ביותר ואז לנסות שוב."
          }
        },
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AdvantageScope соңғы нұсқасына жаңартып, қайта көріңіз."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atualize o AdvantageScope para a versão mais recente e tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actualizează AdvantageScope la cea mai recentă versiune, apoi încearcă din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обновите AdvantageScope до последней версии, затем попробуйте снова."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AdvantageScope'u en son sürüme güncelleyin, ardından tekrar deneyin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将 AdvantageScope 更新到最新版本，然后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將 AdvantageScope 更新至最新版本，然後再試一次。"
          }
        }
      }
    },
